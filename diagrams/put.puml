@startuml
actor Client
participant "Express Router" as Router
participant "Hospital Controller" as Controller
database "Data Store" as DB

Client -> Router: PUT /api/v1/hospitals/:id
Router -> Controller: updateHospital(id, data)
Controller -> DB: findByIdAndUpdate(id, data)
DB --> Controller: updatedHospital
Controller --> Router: 200 OK {success, data}
Router --> Client: JSON Response

@enduml
