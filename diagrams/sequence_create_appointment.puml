@startuml Sequence Diagram - Create Appointment

skinparam sequenceArrowThickness 2
skinparam sequenceParticipant underline

actor "User/Admin" as User
participant "<<middleware>>\nauth.js" as Middleware
participant "<<routes>>\nappointments.js" as Routes
participant "<<controllers>>\nappointments.js" as Controller
participant "<<models>>\nHospital.js" as HospitalModel
participant "<<models>>\nDentist.js" as DentistModel
participant "<<models>>\nAppointment.js" as ApptModel
database "MongoDB" as DB

title Create Appointment (Booking)

User -> Routes : POST /api/v1/hospitals/:hospitalId/appointments\n{apptDate, dentist}\nAuthorization: Bearer <token>
activate Routes

Routes -> Middleware : protect(req, res, next)
activate Middleware

note right of Middleware
  1. Extract token from
     Authorization header
  2. jwt.verify(token, JWT_SECRET)
  3. User.findById(decoded.id)
  4. Set req.user
end note

alt token missing or invalid
  Middleware --> User : 401 Unauthorized\n"Not authorized to access this route"
else token valid
  Middleware --> Routes : next()
  deactivate Middleware

  Routes -> Middleware : authorize('admin', 'user')
  activate Middleware

  alt role not authorized
    Middleware --> User : 403 Forbidden\n"User role is not authorized"
  else role authorized
    Middleware --> Routes : next()
    deactivate Middleware

    Routes -> Controller : addAppointment(req, res, next)
    activate Controller

    Controller -> HospitalModel : Hospital.findById(hospitalId)
    activate HospitalModel
    HospitalModel -> DB : Find hospital
    activate DB
    DB --> HospitalModel : hospital
    deactivate DB
    HospitalModel --> Controller : hospital
    deactivate HospitalModel

    alt hospital not found
      Controller --> User : 404 Not Found\n"No hospital with the id of ..."
    else hospital exists
      Controller -> DentistModel : Dentist.findById(dentistId)
      activate DentistModel
      DentistModel -> DB : Find dentist
      activate DB
      DB --> DentistModel : dentist
      deactivate DB
      DentistModel --> Controller : dentist
      deactivate DentistModel

      alt dentist not found
        Controller --> User : 404 Not Found\n"No dentist with the id of ..."
      else dentist does not belong to hospital
        Controller --> User : 400 Bad Request\n"Dentist does not belong to hospital"
      else dentist valid

        Controller -> ApptModel : Appointment.find({user: userId})
        activate ApptModel
        ApptModel -> DB : Count user's appointments
        activate DB
        DB --> ApptModel : existedAppointments
        deactivate DB
        ApptModel --> Controller : existedAppointments
        deactivate ApptModel

        alt user has >= 1 appointment AND role != admin
          Controller --> User : 400 Bad Request\n"Only 1 booking is allowed per user"
        else within limit or admin
          Controller -> ApptModel : Appointment.create({apptDate,\nuser, hospital, dentist})
          activate ApptModel
          ApptModel -> DB : Insert Appointment
          activate DB
          DB --> ApptModel : appointment
          deactivate DB
          ApptModel --> Controller : appointment
          deactivate ApptModel

          Controller --> User : 200 OK\n{success: true, data: appointment}
        end
      end
    end

    deactivate Controller
  end
end

deactivate Routes

@enduml
