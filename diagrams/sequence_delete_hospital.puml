@startuml Sequence Diagram - Delete Hospital

skinparam sequenceArrowThickness 2
skinparam sequenceParticipant underline

actor "Admin" as Admin
participant "<<middleware>>\nauth.js" as Middleware
participant "<<routes>>\nhospitals.js" as Routes
participant "<<controllers>>\nhospitals.js" as Controller
participant "<<models>>\nHospital.js" as HospitalModel
participant "<<models>>\nAppointment.js" as ApptModel
database "MongoDB" as DB

title Delete Hospital (with Cascade Delete)

Admin -> Routes : DELETE /api/v1/hospitals/:id\nAuthorization: Bearer <token>
activate Routes

Routes -> Middleware : protect(req, res, next)
activate Middleware

note right of Middleware
  1. Extract token from header
  2. jwt.verify(token, JWT_SECRET)
  3. User.findById(decoded.id)
  4. Set req.user
end note

Middleware --> Routes : next()
deactivate Middleware

Routes -> Middleware : authorize('admin')
activate Middleware

alt role is not admin
  Middleware --> Admin : 403 Forbidden\n"User role is not authorized"
else role is admin
  Middleware --> Routes : next()
  deactivate Middleware

  Routes -> Controller : deleteHospital(req, res, next)
  activate Controller

  Controller -> HospitalModel : Hospital.findById(id)
  activate HospitalModel
  HospitalModel -> DB : Find hospital
  activate DB
  DB --> HospitalModel : hospital
  deactivate DB
  HospitalModel --> Controller : hospital
  deactivate HospitalModel

  alt hospital not found
    Controller --> Admin : 400 Bad Request\n{success: false}
  else hospital exists
    Controller -> HospitalModel : hospital.deleteOne()
    activate HospitalModel

    note right of HospitalModel #FFAAAA
      **Pre-deleteOne Middleware Triggered**
      document: true, query: false
    end note

    HospitalModel -> ApptModel : Appointment.deleteMany(\n{hospital: this._id})
    activate ApptModel
    ApptModel -> DB : Delete all appointments\nfor this hospital
    activate DB
    DB --> ApptModel : deleted
    deactivate DB
    ApptModel --> HospitalModel : done
    deactivate ApptModel

    HospitalModel -> DB : Delete hospital document
    activate DB
    DB --> HospitalModel : deleted
    deactivate DB
    HospitalModel --> Controller : done
    deactivate HospitalModel

    Controller --> Admin : 200 OK\n{success: true, data: {}}
  end

  deactivate Controller
end

deactivate Routes

@enduml
