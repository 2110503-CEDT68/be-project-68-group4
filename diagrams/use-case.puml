@startuml
title Hospital Management API - Use Case Diagram

left to right direction

skinparam rectangle<<Client>> {
  BackgroundColor #E8F4FD
  BorderColor #1976D2
  FontColor #0D47A1
}

rectangle "Client" as Client <<Client>>

rectangle "Hospital Management API" {
  together {
    usecase "View all hospitals" as UC_GetAll
    usecase "View hospital details" as UC_GetOne
    usecase "Create hospital" as UC_Create
    usecase "Update hospital" as UC_Update
    usecase "Delete hospital" as UC_Delete
  }
}

Client --> UC_GetAll
Client --> UC_GetOne
Client --> UC_Create
Client --> UC_Update
Client --> UC_Delete

' hidden links to force horizontal alignment of use cases
UC_GetAll -[hidden]-> UC_GetOne
UC_GetOne -[hidden]-> UC_Create
UC_Create -[hidden]-> UC_Update
UC_Update -[hidden]-> UC_Delete

note right of Client
  Could be web app,
  mobile app, or API client
end note

@enduml
