{
  "info": {
    "name": "Dentist Booking API",
    "description": "Full test suite covering all presentation steps 1-12",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",       "value": "http://localhost:5001/api/v1" },
    { "key": "user_token",     "value": "" },
    { "key": "admin_token",    "value": "" },
    { "key": "hospital_id",    "value": "" },
    { "key": "dentist_id",     "value": "" },
    { "key": "appointment_id", "value": "" },
    { "key": "reg_email",      "value": "" },
    { "key": "hacker_email",   "value": "" }
  ],
  "item": [
    {
      "name": "Step 1 - User Registration",
      "item": [
        {
          "name": "Register (valid)",
          "event": [
            { "listen": "prerequest", "script": { "type": "text/javascript", "exec": [
              "pm.collectionVariables.set('reg_email', 'testuser_' + Date.now() + '@gmail.com');"
            ]}},
            { "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Returns token', () => {",
            "  const j = pm.response.json();",
            "  pm.expect(j.token).to.be.a('string');",
            "  pm.collectionVariables.set('user_token', j.token);",
            "});"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"{{reg_email}}\",\n  \"password\": \"123456\",\n  \"tel\": \"0812345678\"\n}" },
            "url": { "raw": "{{base_url}}/auth/register", "host": ["{{base_url}}"], "path": ["auth","register"] }
          }
        },
        {
          "name": "Register - missing tel (validation fail)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 400 - tel required', () => pm.response.to.have.status(400));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"No Tel\",\n  \"email\": \"notel@gmail.com\",\n  \"password\": \"123456\"\n}" },
            "url": { "raw": "{{base_url}}/auth/register", "host": ["{{base_url}}"], "path": ["auth","register"] }
          }
        },
        {
          "name": "Register - missing name (validation fail)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 400 - name required', () => pm.response.to.have.status(400));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"noname@gmail.com\",\n  \"password\": \"123456\",\n  \"tel\": \"0812345678\"\n}" },
            "url": { "raw": "{{base_url}}/auth/register", "host": ["{{base_url}}"], "path": ["auth","register"] }
          }
        },
        {
          "name": "Register - cannot self-assign admin role",
          "event": [
            { "listen": "prerequest", "script": { "type": "text/javascript", "exec": [
              "pm.collectionVariables.set('hacker_email', 'hacker_' + Date.now() + '@gmail.com');"
            ]}},
            { "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Role forced to user', () => pm.expect(pm.response.json().success).to.be.true);"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Hacker\",\n  \"email\": \"{{hacker_email}}\",\n  \"password\": \"123456\",\n  \"tel\": \"0899999999\",\n  \"role\": \"admin\"\n}" },
            "url": { "raw": "{{base_url}}/auth/register", "host": ["{{base_url}}"], "path": ["auth","register"] }
          }
        }
      ]
    },
    {
      "name": "Step 2 - User Login",
      "item": [
        {
          "name": "Login user8 (valid)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Token saved', () => {",
            "  const j = pm.response.json();",
            "  pm.expect(j.token).to.be.a('string');",
            "  pm.collectionVariables.set('user_token', j.token);",
            "});"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"user8@gmail.com\",\n  \"password\": \"12345678\"\n}" },
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth","login"] }
          }
        },
        {
          "name": "Login - wrong password (fail)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 401 - invalid credentials', () => pm.response.to.have.status(401));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"user8@gmail.com\",\n  \"password\": \"wrongpassword\"\n}" },
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth","login"] }
          }
        }
      ]
    },
    {
      "name": "Step 3 - View Dentists (Product)",
      "item": [
        {
          "name": "Get all hospitals",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Has hospitals', () => {",
            "  const j = pm.response.json();",
            "  pm.expect(j.data).to.be.an('array').that.is.not.empty;",
            "});"
          ]}}],
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/hospitals", "host": ["{{base_url}}"], "path": ["hospitals"] }
          }
        },
        {
          "name": "Get all dentists (saves hospital_id + dentist_id)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Has dentists with required fields', () => {",
            "  const j = pm.response.json();",
            "  pm.expect(j.data).to.be.an('array').that.is.not.empty;",
            "  const d = j.data[0];",
            "  pm.expect(d).to.have.property('name');",
            "  pm.expect(d).to.have.property('yearsOfExperience');",
            "  pm.expect(d).to.have.property('areaOfExpertise');",
            "  pm.collectionVariables.set('dentist_id', d._id);",
            "  const hid = d.hospital._id || d.hospital;",
            "  pm.collectionVariables.set('hospital_id', hid);",
            "});"
          ]}}],
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/dentists", "host": ["{{base_url}}"], "path": ["dentists"] }
          }
        },
        {
          "name": "Get dentists for hospital",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Returns dentists for hospital', () => {",
            "  pm.expect(pm.response.json().success).to.be.true;",
            "});"
          ]}}],
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/hospitals/{{hospital_id}}/dentists", "host": ["{{base_url}}"], "path": ["hospitals","{{hospital_id}}","dentists"] }
          }
        },
        {
          "name": "Get all dentists",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Returns dentist list', () => pm.expect(pm.response.json().success).to.be.true);"
          ]}}],
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/dentists", "host": ["{{base_url}}"], "path": ["dentists"] }
          }
        }
      ]
    },
    {
      "name": "Step 4 - Create Booking",
      "item": [
        {
          "name": "Create booking (valid)",
          "event": [
            { "listen": "prerequest", "script": { "type": "text/javascript", "exec": [
              "// Delete any existing booking for user8 so the 1-limit test is clean",
              "const token = pm.collectionVariables.get('user_token');",
              "const base = pm.collectionVariables.get('base_url');",
              "pm.sendRequest({ url: base + '/appointments', method: 'GET', header: { Authorization: 'Bearer ' + token } }, (err, res) => {",
              "  const appts = res.json().data;",
              "  if (appts && appts.length > 0) {",
              "    pm.sendRequest({ url: base + '/appointments/' + appts[0]._id, method: 'DELETE', header: { Authorization: 'Bearer ' + token } }, () => {});",
              "  }",
              "});"
            ]}},
            { "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Appointment created', () => {",
            "  const j = pm.response.json();",
            "  pm.expect(j.success).to.be.true;",
            "  pm.collectionVariables.set('appointment_id', j.data._id);",
            "});"
          ]}}],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{user_token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"apptDate\": \"2026-06-01T10:00:00.000Z\",\n  \"dentist\": \"{{dentist_id}}\"\n}" },
            "url": { "raw": "{{base_url}}/hospitals/{{hospital_id}}/appointments", "host": ["{{base_url}}"], "path": ["hospitals","{{hospital_id}}","appointments"] }
          }
        },
        {
          "name": "Create 2nd booking - exceeds 1 limit (fail)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 400 - only 1 booking allowed', () => pm.response.to.have.status(400));",
            "pm.test('Error message present', () => pm.expect(pm.response.json().success).to.be.false);"
          ]}}],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{user_token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"apptDate\": \"2026-07-01T10:00:00.000Z\",\n  \"dentist\": \"{{dentist_id}}\"\n}" },
            "url": { "raw": "{{base_url}}/hospitals/{{hospital_id}}/appointments", "host": ["{{base_url}}"], "path": ["hospitals","{{hospital_id}}","appointments"] }
          }
        },
        {
          "name": "Create booking - no auth (fail)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 401 - unauthorized', () => pm.response.to.have.status(401));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"apptDate\": \"2026-08-01T10:00:00.000Z\",\n  \"dentist\": \"{{dentist_id}}\"\n}" },
            "url": { "raw": "{{base_url}}/hospitals/{{hospital_id}}/appointments", "host": ["{{base_url}}"], "path": ["hospitals","{{hospital_id}}","appointments"] }
          }
        },
        {
          "name": "Create booking - invalid dentist ID (fail)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 404 - dentist not found', () => pm.response.to.have.status(404));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{user_token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"apptDate\": \"2026-06-01T10:00:00.000Z\",\n  \"dentist\": \"000000000000000000000000\"\n}" },
            "url": { "raw": "{{base_url}}/hospitals/{{hospital_id}}/appointments", "host": ["{{base_url}}"], "path": ["hospitals","{{hospital_id}}","appointments"] }
          }
        }
      ]
    },
    {
      "name": "Step 5 - User View Own Booking",
      "item": [
        {
          "name": "Get my appointments",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Only own appointments returned', () => {",
            "  const j = pm.response.json();",
            "  pm.expect(j.success).to.be.true;",
            "  pm.expect(j.data).to.be.an('array');",
            "});"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{user_token}}" }],
            "url": { "raw": "{{base_url}}/appointments", "host": ["{{base_url}}"], "path": ["appointments"] }
          }
        },
        {
          "name": "Get single appointment",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Has dentist info', () => {",
            "  const j = pm.response.json();",
            "  pm.expect(j.data.dentist).to.exist;",
            "});"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{user_token}}" }],
            "url": { "raw": "{{base_url}}/appointments/{{appointment_id}}", "host": ["{{base_url}}"], "path": ["appointments","{{appointment_id}}"] }
          }
        }
      ]
    },
    {
      "name": "Step 6 - User Edit Booking",
      "item": [
        {
          "name": "Update own appointment",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Date updated', () => pm.expect(pm.response.json().success).to.be.true);"
          ]}}],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{user_token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"apptDate\": \"2026-09-15T14:00:00.000Z\"\n}" },
            "url": { "raw": "{{base_url}}/appointments/{{appointment_id}}", "host": ["{{base_url}}"], "path": ["appointments","{{appointment_id}}"] }
          }
        }
      ]
    },
    {
      "name": "Step 7 - User Delete Booking",
      "item": [
        {
          "name": "Delete own appointment",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Deleted successfully', () => pm.expect(pm.response.json().success).to.be.true);"
          ]}}],
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{user_token}}" }],
            "url": { "raw": "{{base_url}}/appointments/{{appointment_id}}", "host": ["{{base_url}}"], "path": ["appointments","{{appointment_id}}"] }
          }
        }
      ]
    },
    {
      "name": "Step 8 - User Logout",
      "item": [
        {
          "name": "Logout",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Logout success', () => {",
            "  pm.expect(pm.response.json().success).to.be.true;",
            "  pm.collectionVariables.set('user_token', '');",
            "});"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{user_token}}" }],
            "url": { "raw": "{{base_url}}/auth/logout", "host": ["{{base_url}}"], "path": ["auth","logout"] }
          }
        }
      ]
    },
    {
      "name": "Step 9 - Admin Login",
      "item": [
        {
          "name": "Login (admin)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Admin token saved', () => {",
            "  const j = pm.response.json();",
            "  pm.expect(j.token).to.be.a('string');",
            "  pm.collectionVariables.set('admin_token', j.token);",
            "});"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@gmail.com\",\n  \"password\": \"12345678\"\n}" },
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth","login"] }
          }
        }
      ]
    },
    {
      "name": "Step 10-12 - Admin Booking Management",
      "item": [
        {
          "name": "Admin - create booking (setup for 11-12)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Admin booking created', () => {",
            "  const j = pm.response.json();",
            "  pm.expect(j.success).to.be.true;",
            "  pm.collectionVariables.set('appointment_id', j.data._id);",
            "});"
          ]}}],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"apptDate\": \"2026-10-01T09:00:00.000Z\",\n  \"dentist\": \"{{dentist_id}}\"\n}" },
            "url": { "raw": "{{base_url}}/hospitals/{{hospital_id}}/appointments", "host": ["{{base_url}}"], "path": ["hospitals","{{hospital_id}}","appointments"] }
          }
        },
        {
          "name": "Step 10 - Admin view ALL appointments",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Admin sees all appointments', () => {",
            "  const j = pm.response.json();",
            "  pm.expect(j.success).to.be.true;",
            "  pm.expect(j.data).to.be.an('array');",
            "});"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": { "raw": "{{base_url}}/appointments", "host": ["{{base_url}}"], "path": ["appointments"] }
          }
        },
        {
          "name": "Step 11 - Admin edit ANY appointment",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Updated by admin', () => pm.expect(pm.response.json().success).to.be.true);"
          ]}}],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"apptDate\": \"2026-11-20T11:00:00.000Z\"\n}" },
            "url": { "raw": "{{base_url}}/appointments/{{appointment_id}}", "host": ["{{base_url}}"], "path": ["appointments","{{appointment_id}}"] }
          }
        },
        {
          "name": "Step 12 - Admin delete ANY appointment",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Deleted by admin', () => pm.expect(pm.response.json().success).to.be.true);"
          ]}}],
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": { "raw": "{{base_url}}/appointments/{{appointment_id}}", "host": ["{{base_url}}"], "path": ["appointments","{{appointment_id}}"] }
          }
        }
      ]
    }
  ]
}
